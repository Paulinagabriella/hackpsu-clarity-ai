{
  "manifest_version": 3,
  "name": "Clarity AI",
  "version": "1.0.0",
  "description": "Social media safety assistant for live post moderation.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://clarity-ai-backend-zv30.onrender.com"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}